<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Modern Auth</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <!-- Ambient glow background -->
    <div class="glow-bg">
      <div class="glow glow1"></div>
      <div class="glow glow2"></div>
    </div>

    <div class="login-wrapper">
      <div class="login-card">
        <div class="login-logo">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="14" fill="url(#logo-grad)" />
            <path d="M16 34V20H32V34" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 34V26" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8 22L24 10L40 22" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="logo-grad" x1="0" y1="0" x2="48" y2="48">
                <stop stop-color="#ff8c3b"/>
                <stop offset="1" stop-color="#ff4e50"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h2 class="login-title">Welcome Back</h2>
        <p class="login-subtitle">Sign in to continue to Modern Auth</p>

        <form method="POST" action="/login" class="login-form">
          <input type="hidden" name="client_id" value="<%= client_id %>" />
          <input type="hidden" name="redirect_uri" value="<%= redirect_uri %>" />
          <input type="hidden" name="scope" value="<%= scope %>" />
          <input type="hidden" name="code_challenge" value="<%= code_challenge %>" />
          <input type="hidden" name="code_challenge_method" value="<%= code_challenge_method %>" />

          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your password"
              required
              autocomplete="current-password"
            />
          </div>
          <button type="submit" class="login-btn">Login</button>
        </form>

        <p class="login-footer-text">
          Protected by <span class="brand-text">OAuth 2.0 + PKCE</span>
        </p>
      </div>
    </div>
  </body>
</html>
