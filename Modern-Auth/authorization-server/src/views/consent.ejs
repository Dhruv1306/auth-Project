<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authorize — Modern Auth</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <!-- Ambient glow background -->
    <div class="glow-bg">
      <div class="glow glow1"></div>
      <div class="glow glow2"></div>
    </div>

    <div class="consent-wrapper">
      <div class="consent-card">
        <!-- Shield Icon -->
        <div class="consent-icon">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="56" height="56" rx="16" fill="url(#shield-grad)" opacity="0.12"/>
            <path d="M28 8L42 16V28C42 37.4 35.8 46 28 48C20.2 46 14 37.4 14 28V16L28 8Z"
              stroke="url(#shield-stroke)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M22 28L26 32L34 24"
              stroke="url(#shield-stroke)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="shield-grad" x1="0" y1="0" x2="56" y2="56">
                <stop stop-color="#ff8c3b"/>
                <stop offset="1" stop-color="#ff4e50"/>
              </linearGradient>
              <linearGradient id="shield-stroke" x1="14" y1="8" x2="42" y2="48">
                <stop stop-color="#ff8c3b"/>
                <stop offset="1" stop-color="#ff4e50"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <h2 class="consent-title">Authorization Request</h2>
        <p class="consent-subtitle">
          An application is requesting access to your account
        </p>

        <!-- App Info -->
        <div class="consent-app-info">
          <div class="consent-app-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="28" height="28" rx="8" fill="rgba(255,140,59,0.15)"/>
              <rect x="4" y="4" width="20" height="20" rx="4" stroke="#ff8c3b" stroke-width="1.5" fill="none"/>
              <rect x="8" y="8" width="5" height="5" rx="1" fill="#ff8c3b"/>
              <rect x="15" y="8" width="5" height="5" rx="1" fill="#ff4e50"/>
              <rect x="8" y="15" width="5" height="5" rx="1" fill="#ff4e50"/>
              <rect x="15" y="15" width="5" height="5" rx="1" fill="#ff8c3b"/>
            </svg>
          </div>
          <div class="consent-app-details">
            <span class="consent-app-name"><%= client_id %></span>
            <span class="consent-app-label">wants to access your account</span>
          </div>
        </div>

        <!-- Scopes -->
        <div class="consent-scopes">
          <p class="consent-scopes-label">This will allow the app to:</p>
          <ul class="consent-scopes-list">
            <% const scopes = scope.split(' '); %>
            <% scopes.forEach(function(s) { %>
              <li>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="9" cy="9" r="8" stroke="#ff8c3b" stroke-width="1.5" fill="rgba(255,140,59,0.08)"/>
                  <path d="M6 9L8 11L12 7" stroke="#ff8c3b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span><%= s %></span>
              </li>
            <% }); %>
          </ul>
        </div>

        <!-- Form -->
        <form method="POST" action="/consent" class="consent-form">
          <input type="hidden" name="client_id" value="<%= client_id %>" />
          <input type="hidden" name="redirect_uri" value="<%= redirect_uri %>" />
          <input type="hidden" name="scope" value="<%= scope %>" />
          <input type="hidden" name="user_id" value="<%= user.id %>" />
          <input type="hidden" name="code_challenge" value="<%= code_challenge %>" />
          <input type="hidden" name="code_challenge_method" value="<%= code_challenge_method %>" />

          <div class="consent-actions">
            <button type="submit" class="consent-allow-btn">Allow Access</button>
            <button type="button" class="consent-deny-btn" onclick="window.history.back()">Deny</button>
          </div>
        </form>

        <p class="consent-footer-text">
          You can revoke access at any time. Protected by <span class="brand-text">OAuth 2.0 + PKCE</span>
        </p>
      </div>
    </div>
  </body>
</html>
