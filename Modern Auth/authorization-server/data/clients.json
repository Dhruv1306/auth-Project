// Registered OAuth Clients
// These are applications that can use this auth server
// In Basic Auth, there's no concept of this - the app IS the auth system
// In OAuth, apps must be registered first

[
  {
    "client_id": "my-client-app",
    "client_name": "My Client Application",
    "redirect_uris": ["http://localhost:3000/callback.html"],
    "allowed_scopes": ["openid", "profile", "email", "admin"],
    "token_endpoint_auth_method": "none"
  }
]
